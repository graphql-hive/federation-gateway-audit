{
  "name": "@graphql-hive/federation-gateway-audit",
  "version": "0.0.0",
  "description": "Audit tool for Apollo Federation Gateway",
  "repository": {
    "type": "git",
    "url": "https://github.com/graphql-hive/federation-gateway-audit"
  },
  "homepage": "https://the-guild.dev/graphql/hive/federation-gateway-audit",
  "author": {
    "email": "contact@the-guild.dev",
    "name": "The Guild",
    "url": "https://the-guild.dev"
  },
  "license": "MIT",
  "bin": {
    "graphql-federation-audit": "./dist/cli.js"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "scripts": {
    "start": "tsx ./src/cli.ts",
    "summary": "tsx ./src/summary.ts",
    "build": "pkgroll",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@apollo/composition": "2.13.1",
    "@apollo/subgraph": "2.13.1",
    "async-retry": "1.3.3",
    "fets": "0.8.5",
    "get-port": "7.1.0",
    "graphql": "16.13.1",
    "graphql-yoga": "5.18.1",
    "jest-diff": "30.3.0",
    "kill-port-process": "4.0.2",
    "wait-on": "9.0.4",
    "detect-port": "2.1.0",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "@apollo/gateway": "2.13.1",
    "@apollo/server": "5.4.0",
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@graphql-hive/gateway": "2.5.5",
    "@graphql-hive/router-runtime": "1.1.15",
    "@as-integrations/express5": "1.1.2",
    "@types/async-retry": "1.4.9",
    "@types/express": "5.0.6",
    "@types/node": "24.12.0",
    "@types/wait-on": "5.3.4",
    "@types/yargs": "17.0.35",
    "express": "5.2.1",
    "prettier": "3.8.1",
    "pkgroll": "2.27.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "wgc": "0.109.0"
  },
  "overrides": {
    "cross-spawn": "7.0.6",
    "graphql": "16.13.1",
    "js-yaml": "4.1.1",
    "tmp": "0.2.5",
    "@modelcontextprotocol/sdk": "1.27.1"
  },
  "packageManager": "npm@11.11.0"
}